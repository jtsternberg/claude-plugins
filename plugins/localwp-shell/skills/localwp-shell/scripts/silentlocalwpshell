#!/usr/bin/env bash
#
# silentlocalwpshell
#
# Wrapper for localwpshell that runs it in silent mode.
# Useful for scripts that just need the env without the chatter.
#
# Usage:
#   silentlocalwpshell wp plugin list

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$SCRIPT_DIR/localwpshell" --silent "$@"
